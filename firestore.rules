rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: Telegram User ID (string)
    // Fields:
    //   - username: string (optional)
    //   - language: string ('ru' or 'uz')
    //   - utm_source: string (optional)
    //   - step: number
    //   - joined_at: timestamp
    //
    // Collection: applications
    // Document ID: Auto-generated
    // Fields:
    //   - user_id: number
    //   - full_name: string
    //   - age_city: string
    //   - social_link: string
    //   - photo_file_id: string
    //   - video_file_id: string
    //   - status: string ('pending', 'approved', 'rejected')
    //   - created_at: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "kyusupov727@gmail.com" && request.auth.token.email_verified == true);
    }

    // Rules
    match /users/{userId} {
      // Only admins can read, update, delete users from the frontend.
      // The Telegram bot uses firebase-admin and bypasses these rules.
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    match /applications/{appId} {
      // Only admins can read, update, delete applications from the frontend.
      // The Telegram bot uses firebase-admin and bypasses these rules.
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
